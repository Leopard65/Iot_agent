<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
        <include domain="sharedpref" path="." />
        <!-- API 密钥等敏感设置存于此 DataStore，禁止进入云备份 -->
        <exclude domain="file" path="datastore/iotgpt_settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
        <include domain="sharedpref" path="." />
        <!-- 换机迁移同样排除密钥，避免明文密钥随设备转移 -->
        <exclude domain="file" path="datastore/iotgpt_settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
